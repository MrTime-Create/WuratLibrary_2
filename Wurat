		function TabFunctions:CreateSlider(SliderSet)
			local SliderFrame = Instance.new("Frame", TabPage)
			SliderFrame.Size = UDim2.new(0.9, 0, 0, 60)
			SliderFrame.BackgroundColor3 = Color3.fromRGB(40, 40, 40)
			Instance.new("UICorner", SliderFrame).CornerRadius = UDim.new(0, 6)
			CreateStroke(SliderFrame, Color3.fromRGB(60, 60, 60), 1)

			local Title = Instance.new("TextLabel", SliderFrame)
			Title.Text = SliderSet.Name .. ": " .. SliderSet.CurrentValue .. " " .. (SliderSet.Suffix or "")
			Title.Size = UDim2.new(1, -20, 0, 25)
			Title.Position = UDim2.new(0, 12, 0, 5)
			Title.BackgroundTransparency = 1
			Title.TextColor3 = Color3.new(1,1,1)
			Title.Font = Enum.Font.FredokaOne
			Title.TextXAlignment = Enum.TextXAlignment.Left
			applyConstraint(Title, 14)

			local Hitbox = Instance.new("TextButton", SliderFrame)
			Hitbox.Size = UDim2.new(0.92, 0, 0, 26) 
			Hitbox.Position = UDim2.new(0.04, 0, 0.5, 0)
			Hitbox.BackgroundTransparency = 1
			Hitbox.Text = ""

			local VisualBar = Instance.new("Frame", Hitbox)
			VisualBar.Size = UDim2.new(1, 0, 0, 6)
			VisualBar.AnchorPoint = Vector2.new(0, 0.5)
			VisualBar.Position = UDim2.new(0, 0, 0.5, 0)
			VisualBar.BackgroundColor3 = Color3.fromRGB(25, 25, 25)
			Instance.new("UICorner", VisualBar).CornerRadius = UDim.new(1, 0)

			local Fill = Instance.new("Frame", VisualBar)
			local initPercent = math.clamp((SliderSet.CurrentValue - SliderSet.Range[1])/(SliderSet.Range[2]-SliderSet.Range[1]), 0, 1)
			Fill.Size = UDim2.new(initPercent, 0, 1, 0)
			Fill.BackgroundColor3 = Color3.fromRGB(0, 150, 255)
			Instance.new("UICorner", Fill).CornerRadius = UDim.new(1, 0)

			local Knob = Instance.new("Frame", Fill)
			Knob.Size = UDim2.new(0, 14, 0, 14)
			Knob.AnchorPoint = Vector2.new(0.5, 0.5)
			Knob.Position = UDim2.new(1, 0, 0.5, 0)
			Knob.BackgroundColor3 = Color3.fromRGB(255, 255, 255)
			Instance.new("UICorner", Knob).CornerRadius = UDim.new(1, 0)
			CreateStroke(Knob, Color3.fromRGB(200, 200, 200), 1)

			local function Update()
				local mousePos = UserInputService:GetMouseLocation().X
				local barPos = VisualBar.AbsolutePosition.X
				local barSize = VisualBar.AbsoluteSize.X
				local percent = math.clamp((mousePos - barPos) / barSize, 0, 1)

				local val = SliderSet.Range[1] + (percent * (SliderSet.Range[2] - SliderSet.Range[1]))
				val = math.floor(val / SliderSet.Increment) * SliderSet.Increment

				local newPercent = (val - SliderSet.Range[1])/(SliderSet.Range[2]-SliderSet.Range[1])
				PlayTween(Fill, TweenInfo.new(0.1, Enum.EasingStyle.Sine), {Size = UDim2.new(newPercent, 0, 1, 0)})
				Title.Text = SliderSet.Name .. ": " .. val .. " " .. (SliderSet.Suffix or "")
				SliderSet.Callback(val)
			end

			local drag = false
			Hitbox.InputBegan:Connect(function(i) 
				if i.UserInputType == Enum.UserInputType.MouseButton1 or i.UserInputType == Enum.UserInputType.Touch then 
					drag = true
					PlayTween(Knob, TweenInfo.new(0.15, Enum.EasingStyle.Back, Enum.EasingDirection.Out), {Size = UDim2.new(0, 18, 0, 18)})
					Update() 
				end 
			end)
			UserInputService.InputEnded:Connect(function(i) 
				if i.UserInputType == Enum.UserInputType.MouseButton1 or i.UserInputType == Enum.UserInputType.Touch then 
					drag = false 
					PlayTween(Knob, TweenInfo.new(0.15, Enum.EasingStyle.Sine), {Size = UDim2.new(0, 14, 0, 14)})
				end 
			end)
			UserInputService.InputChanged:Connect(function(i) 
				if drag and (i.UserInputType == Enum.UserInputType.MouseMovement or i.UserInputType == Enum.UserInputType.Touch) then Update() end 
			end)
			return SliderFrame
		end

