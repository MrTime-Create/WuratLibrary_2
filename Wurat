		function TabFunctions:CreateDropdown(DropSet)
			local Dropped = false
			local DropFrame = Instance.new("Frame", TabPage)
			DropFrame.Size = UDim2.new(0.9, 0, 0, 40)
			DropFrame.BackgroundColor3 = Color3.fromRGB(40, 40, 40)
			DropFrame.ClipsDescendants = true -- ตัวนี้จะคุมการซ่อน/แสดง Option
			DropFrame.ZIndex = 5 -- ดันขึ้นมาให้อยู่เหนือตัวอื่น
			Instance.new("UICorner", DropFrame).CornerRadius = UDim.new(0, 6)
			CreateStroke(DropFrame, Color3.fromRGB(60, 60, 60), 1)

			local DropBtn = Instance.new("TextButton", DropFrame)
			DropBtn.Size = UDim2.new(1, 0, 0, 40)
			DropBtn.BackgroundTransparency = 1
			DropBtn.Text = "  " .. DropSet.Name .. ": " .. (DropSet.CurrentValue or "None")
			DropBtn.TextColor3 = Color3.new(1, 1, 1)
			DropBtn.Font = Enum.Font.FredokaOne
			DropBtn.TextXAlignment = Enum.TextXAlignment.Left
			DropBtn.ZIndex = 7
			applyConstraint(DropBtn, 15)

			local Arrow = Instance.new("TextLabel", DropFrame)
			Arrow.Size = UDim2.new(0, 30, 0, 40)
			Arrow.Position = UDim2.new(1, -35, 0, 0)
			Arrow.BackgroundTransparency = 1
			Arrow.Text = "▼"
			Arrow.TextColor3 = Color3.fromRGB(180, 180, 180)
			Arrow.ZIndex = 7

			-- ส่วนของรายการเลือก (ปรับให้เห็นชัดขึ้น)
			local OptionScroll = Instance.new("ScrollingFrame", DropFrame)
			OptionScroll.Name = "OptionScroll"
			OptionScroll.Position = UDim2.new(0, 5, 0, 45) -- ขยับลงมาจากปุ่มหลักนิดนึง
			OptionScroll.Size = UDim2.new(1, -10, 1, -50)
			OptionScroll.BackgroundTransparency = 1
			OptionScroll.BorderSizePixel = 0
			OptionScroll.ScrollBarThickness = 2
			OptionScroll.ZIndex = 6
			OptionScroll.CanvasSize = UDim2.new(0, 0, 0, 0)
			OptionScroll.AutomaticCanvasSize = Enum.AutomaticSize.Y -- สำคัญ: ให้มันยืดตามจำนวนปุ่มเอง

			local OptionLayout = Instance.new("UIListLayout", OptionScroll)
			OptionLayout.Padding = UDim.new(0, 4)
			OptionLayout.SortOrder = Enum.SortOrder.LayoutOrder

			-- คำนวณความสูง (เผื่อพื้นที่ให้ Padding ด้วย)
			local DropdownMaxHeight = 40 + math.clamp((#DropSet.Options * 39), 40, 160)

			local function CloseDropdown()
				Dropped = false
				PlayTween(DropFrame, TweenInfo.new(0.3, Enum.EasingStyle.Quart, Enum.EasingDirection.Out), {Size = UDim2.new(0.9, 0, 0, 40)})
				PlayTween(Arrow, TweenInfo.new(0.3), {Rotation = 0})
			end

			local function OpenDropdown()
				Dropped = true
				PlayTween(DropFrame, TweenInfo.new(0.4, Enum.EasingStyle.Quart, Enum.EasingDirection.Out), {Size = UDim2.new(0.9, 0, 0, DropdownMaxHeight)})
				PlayTween(Arrow, TweenInfo.new(0.3), {Rotation = 180})
			end

			for _, option in ipairs(DropSet.Options) do
				local Opt = Instance.new("TextButton", OptionScroll)
				Opt.Size = UDim2.new(1, 0, 0, 35) -- กำหนดความสูงที่แน่นอน
				Opt.BackgroundColor3 = Color3.fromRGB(50, 50, 50) -- ปรับสีให้ต่างจากพื้นหลังนิดหน่อยจะได้เห็นชัด
				Opt.Text = tostring(option)
				Opt.TextColor3 = Color3.fromRGB(255, 255, 255)
				Opt.Font = Enum.Font.FredokaOne
				Opt.ZIndex = 8

				Instance.new("UICorner", Opt).CornerRadius = UDim.new(0, 4)
				applyConstraint(Opt, 14)

				Opt.MouseButton1Click:Connect(function()
					DropBtn.Text = "  " .. DropSet.Name .. ": " .. option
					DropSet.Callback(option)
					CloseDropdown()
				end)
			end

			DropBtn.MouseButton1Click:Connect(function()
				if Dropped then CloseDropdown() else OpenDropdown() end
			end)

			return DropFrame
		end

		function TabFunctions:CreateSection(SectionName, Setting)
			local ColorPresets = {
				["Red"] = Color3.fromRGB(255, 80, 80),
				["Green"] = Color3.fromRGB(100, 255, 100),
				["Blue"] = Color3.fromRGB(0, 150, 255),
				["Yellow"] = Color3.fromRGB(255, 255, 100),
				["Purple"] = Color3.fromRGB(180, 100, 255),
				["White"] = Color3.fromRGB(255, 255, 255)
			}

			local SectionLabel = Instance.new("TextLabel", TabPage)
			SectionLabel.Size = UDim2.new(0.9, 0, 0, 25)
			SectionLabel.BackgroundTransparency = 1
			SectionLabel.Text = "— " .. SectionName .. " —"

			if Setting and Setting.Color then
				if typeof(Setting.Color) == "string" then SectionLabel.TextColor3 = ColorPresets[Setting.Color] or Color3.fromRGB(255, 255, 255)
				elseif typeof(Setting.Color) == "Color3" then SectionLabel.TextColor3 = Setting.Color end
			else SectionLabel.TextColor3 = Color3.fromRGB(150, 150, 150) end

			SectionLabel.Font = Enum.Font.FredokaOne
			applyConstraint(SectionLabel, 13)
			return SectionLabel
		end

		return TabFunctions
	end

	return WindowFunctions
end

return Window
